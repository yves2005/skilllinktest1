rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Strict Default Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // Pure, hardened architectural global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com' ||
        request.auth.token.firebase.sign_in_provider == 'password'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Entity Schemas & Boundaries Constraints (Anti-Update-Gap Validation Blueprints)

    function isValidUser(u) {
      return u.keys().hasAll(['uid', 'email', 'role']) 
        && u.uid is string && u.uid.size() <= 128
        && u.email is string && u.email.size() <= 200
        && u.role is string && (u.role == 'client' || u.role == 'freelance' || u.role == 'entrepreneur')
        && (!u.keys().hasAny(['bio']) || (u.bio is string && u.bio.size() <= 1000))
        && (!u.keys().hasAny(['title']) || (u.title is string && u.title.size() <= 150))
        && (!u.keys().hasAny(['location']) || (u.location is string && u.location.size() <= 150))
        && (!u.keys().hasAny(['tjm']) || (u.tjm is number || u.tjm is int))
        && (!u.keys().hasAny(['skills']) || (u.skills is list && u.skills.size() <= 20))
        && (!u.keys().hasAny(['isAvailable']) || (u.isAvailable is bool))
        && (!u.keys().hasAny(['displayName']) || (u.displayName is string && u.displayName.size() <= 200))
        && (!u.keys().hasAny(['reviewsCount']) || (u.reviewsCount is number || u.reviewsCount is int))
        && (!u.keys().hasAny(['rating']) || (u.rating is number || u.rating is int))
        && (!u.keys().hasAny(['portfolio']) || (u.portfolio is list && u.portfolio.size() <= 50))
        && (!u.keys().hasAny(['createdAt']) || (u.createdAt is string && u.createdAt.size() <= 100));
    }

    function isValidReview(r) {
      return r.keys().hasAll(['author', 'text', 'rating', 'authorId'])
        && r.author is string && r.author.size() <= 200
        && r.text is string && r.text.size() <= 5000
        && (r.rating is int || r.rating is number) && r.rating >= 1 && r.rating <= 5
        && r.authorId is string && r.authorId.size() <= 128
        && (r.authorId == request.auth.uid || r.authorId == 'anonymous')
        && (!r.keys().hasAny(['createdAt']) || r.createdAt == request.time);
    }

    function isValidService(s) {
      return s.keys().hasAll(['title', 'category', 'price', 'auteur', 'authorId'])
        && s.title is string && s.title.size() <= 200
        && s.category is string && s.category.size() <= 100
        && s.price is string && s.price.size() <= 100
        && (!s.keys().hasAny(['d\u00e9lai']) || s['d\u00e9lai'] is string)
        && s.auteur is string && s.auteur.size() <= 200
        && s.authorId is string && s.authorId == request.auth.uid;
    }

    function isValidConversation(c) {
      return c.keys().hasAll(['participants', 'updatedAt'])
        && c.participants is list && c.participants.size() == 2
        && c.participants[0] is string
        && c.participants[1] is string
        && (request.auth.uid == c.participants[0] || request.auth.uid == c.participants[1]);
    }

    function isValidMessageCreate(m) {
      return m.keys().hasAll(['text', 'senderId', 'timestamp'])
        && m.text is string && m.text.size() <= 5000
        && m.senderId is string && m.senderId == request.auth.uid
        && (!m.keys().hasAny(['senderName']) || (m.senderName is string && m.senderName.size() <= 200))
        && (!m.keys().hasAny(['time']) || (m.time is string && m.time.size() <= 20))
        && (!m.keys().hasAny(['read']) || m.read is bool);
    }

    function isValidProject(p) {
      return p.keys().hasAll(['id', 'title', 'freelanceId', 'clientId', 'status', 'price'])
        && p.id is string && p.id.size() <= 128
        && p.title is string && p.title.size() <= 250
        && p.freelanceId is string && p.freelanceId.size() <= 128
        && p.clientId is string && p.clientId.size() <= 128
        && p.status is string && (p.status == 'in-progress' || p.status == 'validation' || p.status == 'completed')
        && p.price is string && p.price.size() <= 100;
    }

    function isValidSecurityLog(l) {
      return l.keys().hasAll(['userId', 'date', 'event', 'status', 'ip'])
        && l.userId is string && l.userId == request.auth.uid
        && l.date is string && l.date.size() <= 100
        && l.event is string && l.event.size() <= 500
        && l.status is string && (l.status == 'S\u00e9curis\u00e9' || l.status == 'Autoris\u00e9' || l.status == 'Avertissement' || l.status == 'Danger' || l.status == 'Activation' || l.status == 'Succ\u00e8s')
        && l.ip is string && l.ip.size() <= 45;
    }

    function isValidNotification(n) {
      return n.keys().hasAll(['userId', 'type', 'title', 'message', 'createdAt'])
        && n.userId is string && n.userId.size() <= 128
        && n.type is string && n.type.size() <= 100
        && n.title is string && n.title.size() <= 200
        && n.message is string && n.message.size() <= 1000
        && (!n.keys().hasAny(['read']) || n.read is bool)
        && (!n.keys().hasAny(['soundType']) || n.soundType is string)
        && n.createdAt is string && n.createdAt.size() <= 100;
    }

    // Document Path Matching & Operations Guarding

    match /publications/{pubId} {
      allow read: if true;
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
      }
    }

    // 1. Users Profiles - Isolated & self-update only
    match /users/{userId} {
      allow read: if true; // Allowed for public marketplace visibility
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && (
        (userId == request.auth.uid && isValidUser(incoming()) && incoming().uid == resource.data.uid) ||
        (incoming().diff(resource.data).affectedKeys().hasOnly(['reviewsCount', 'rating']))
      );
      allow delete: if false;

      match /archives/{archiveId} {
        allow read, write: if isSignedIn() && userId == request.auth.uid && isValidId(archiveId);
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidReview(incoming());
        allow update: if false;
        allow delete: if isSignedIn() && (
          (resource.data.authorId == request.auth.uid) || 
          (userId == request.auth.uid)
        );
      }
    }

    // 2. Services Marketplace
    match /services/{serviceId} {
      allow read: if true; // Public access allowed
      allow create: if true;
      allow update: if isSignedIn() && isValidId(serviceId) && resource.data.authorId == request.auth.uid && isValidService(incoming()) 
                       && incoming().authorId == resource.data.authorId;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // 3. Conversation & Message (Derive-Access & Relational Sync)
    match /conversations/{conversationId} {
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && isValidId(conversationId) && isValidConversation(incoming());
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants) && isValidConversation(incoming())
                       && incoming().participants == resource.data.participants;
      allow delete: if false;

      // Unbounded message list scalability isolation (Subcollection instead of map arrays)
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidId(messageId) && isValidMessageCreate(incoming()) && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
        allow update: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants) 
                      && incoming().diff(resource.data).affectedKeys().hasOnly(['read']) 
                      && incoming().read == true 
                      && resource.data.senderId != request.auth.uid;
        allow delete: if false;
      }
    }

    // 4. Projects Trackers
    match /projects/{projectId} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.freelanceId);
      allow list: if isSignedIn() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.freelanceId);
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming()) && (request.auth.uid == incoming().clientId || request.auth.uid == incoming().freelanceId);
      allow update: if isSignedIn() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.freelanceId) 
                       && isValidProject(incoming())
                       && incoming().clientId == resource.data.clientId
                       && incoming().freelanceId == resource.data.freelanceId
                       && incoming().id == resource.data.id;
      allow delete: if false;
    }

    // 5. Hardened Security logs
    match /security_logs/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(logId) && isValidSecurityLog(incoming());
      allow update, delete: if false;
    }

    // 6. Notifications
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidNotification(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 7. Video Testimonials
    match /video_testimonials/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.freelanceId == request.auth.uid);
    }
  }
}
